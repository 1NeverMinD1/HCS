{
  "kind": "collectionType",
  "collectionName": "news",
  "info": {
    "singularName": "new",
    "pluralName": "news",
    "displayName": "New"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title_ru": {
      "type": "string",
      "required": true
    },
    "title_kk": {
      "type": "string"
    },
    "title_en": {
      "type": "string"
    },
    "desc_ru": {
      "type": "text",
      "maxLength": 200,
      "required": true
    },
    "desc_kk": {
      "type": "text"
    },
    "desc_en": {
      "type": "text"
    },
    "isFeatured": {
      "type": "boolean"
    },
    "main": {
      "type": "boolean"
    },
    "publishDate": {
      "type": "datetime",
      "required": true
    },
    "content_ru": {
      "type": "blocks",
      "required": true
    },
    "content_kk": {
      "type": "blocks"
    },
    "content_en": {
      "type": "blocks"
    },
    "desc_img": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "mappedBy": "news"
    },
    "header_cats": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::header-cat.header-cat",
      "mappedBy": "news"
    },
    "SEO": {
      "type": "component",
      "component": "content.seo",
      "repeatable": false
    },
    "OG": {
      "type": "component",
      "component": "content.og",
      "repeatable": false
    },
    "slug": {
      "type": "uid",
      "targetField": "title_ru"
    }
  }
}
