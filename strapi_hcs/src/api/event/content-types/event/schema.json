{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "desc": {
      "type": "string"
    },
    "start": {
      "type": "date"
    },
    "end": {
      "type": "date"
    },
    "place": {
      "type": "string"
    },
    "amount": {
      "type": "integer"
    },
    "desc_img": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "event_cats": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event-cat.event-cat",
      "inversedBy": "events"
    }
  }
}
